{
  "name": "@eminuckan/mimir-core",
  "version": "0.2.0",
  "description": "Framework-agnostic SaaS primitives for auth, identity, multi-tenancy, permissions, and API access.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "packageManager": "pnpm@9.15.9",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./react-router": {
      "types": "./dist/react-router/index.d.ts",
      "import": "./dist/react-router/index.js"
    },
    "./react-router/server": {
      "types": "./dist/react-router/server.d.ts",
      "import": "./dist/react-router/server.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./auth/server": {
      "types": "./dist/auth/server.d.ts",
      "import": "./dist/auth/server.js"
    },
    "./permissions": {
      "types": "./dist/permissions/index.d.ts",
      "import": "./dist/permissions/index.js"
    },
    "./tenant": {
      "types": "./dist/tenant/index.d.ts",
      "import": "./dist/tenant/index.js"
    },
    "./tenant/server": {
      "types": "./dist/tenant/server.d.ts",
      "import": "./dist/tenant/server.js"
    },
    "./identity": {
      "types": "./dist/identity/index.d.ts",
      "import": "./dist/identity/index.js"
    },
    "./identity/server": {
      "types": "./dist/identity/server.d.ts",
      "import": "./dist/identity/server.js"
    },
    "./api-client": {
      "types": "./dist/api-client/index.d.ts",
      "import": "./dist/api-client/index.js"
    },
    "./api-client/server": {
      "types": "./dist/api-client/server.d.ts",
      "import": "./dist/api-client/server.js"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "import": "./dist/logging/index.js"
    },
    "./signalr": {
      "types": "./dist/signalr/index.d.ts",
      "import": "./dist/signalr/index.js"
    },
    "./query-client": {
      "types": "./dist/query-client/index.d.ts",
      "import": "./dist/query-client/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "dependencies": {
    "@microsoft/signalr": "^9.0.0",
    "axios": "^1.7.0",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.1",
    "oauth4webapi": "^3.3.0",
    "tailwind-merge": "^2.5.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "eslint": "^9.0.0",
    "globals": "^17.4.0",
    "rimraf": "^6.0.0",
    "tsdown": "^0.9.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "api-client",
    "auth",
    "framework-agnostic",
    "multi-tenant",
    "oauth",
    "oidc",
    "react-router",
    "saas",
    "signalr",
    "tanstack-query",
    "typescript",
    "zustand"
  ],
  "homepage": "https://github.com/eminuckan/mimir-core#readme",
  "bugs": {
    "url": "https://github.com/eminuckan/mimir-core/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eminuckan/mimir-core.git"
  },
  "author": "Muhammet Emin Uckan <eminuckan@gmail.com>",
  "license": "MIT",
  "private": false
}
